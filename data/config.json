{
  "ai": {
    "provider": "openai",
    "model": "deepseek-ai/DeepSeek-V3.2",
    "api_key_env": "OPENAI_API_KEY",
    "base_url":"https://api.siliconflow.cn/v1",
    "throttle_sec":0.06,
    "languages": ["zh"]
  },
  "sources": {},
  "filtering": {
    "ai_score_threshold": 5.0,
    "time_window_hours": 24
  },
  "email": {
    "enabled": true,
    "smtp_server": "smtp.resend.com",
    "smtp_port": 456,
    "smtp_username": "resend",
    "password_env": "RESEND_API_KEY",
    "imap_enabled": false,
    "imap_server": "",
    "imap_port": 993,
    "email_address": "noreply@send.lapsap.moe",
    "sender_name": "Horizon Daily"
  },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "first",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": null,
    "request_body": {
      "title": "#{message_title}",
      "kind": "#{message_kind}",
      "date": "#{timestamp}",
      "summaary": "#{summary?limit=2000&split=---}",
      "url": "#{item_url}"
    },
    "headers": ""
  }
}
